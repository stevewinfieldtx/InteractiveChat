# =============================================================================
# Rain Networks — Voice Agent (api.py) — Railway environment template
# Copy into: Railway → your service → Variables → "Raw Editor", then fill secrets.
#
# RULE OF THUMB
#   • NO VITE_ prefix  -> server-side only (the Python backend). Secrets go here.
#   • VITE_ prefix     -> bundled into the browser (the React frontend). PUBLIC.
#   • NEVER put a secret behind VITE_ — it ends up readable in the page source.
#
# Values shown as sk-.../re-.../tvly-... are PLACEHOLDERS — paste your real keys.
# =============================================================================


# ===== BACKEND (server-side — no VITE_, holds all secrets) ===================

# Postgres — Railway service reference, leave exactly as-is
DATABASE_URL=${{Postgres.DATABASE_URL}}

# OpenRouter — LLM for research synthesis + the AI sales brief
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=anthropic/claude-haiku-4-5

# TDE — PRIMARY customer/industry research engine
TDE_API_URL=https://targeteddecomposition-production.up.railway.app
TDE_API_KEY=tde-...

# Tavily — fallback research only.
# NOTE: single underscore. Your current var "TAVILY_API__KEY" has TWO and is ignored.
TAVILY_API_KEY=tvly-...

# ElevenLabs — server-side: polls the live transcript + renders the demo page.
# This REPLACES VITE_ELEVENLABS_API_KEY (a key must never be public).
ELEVENLABS_API_KEY=sk_...            # paste a ROTATED key — the old one was public
ELEVENLABS_AGENT_ID=agent_5101kty2ztmme25aspqycwp7mpsm   # the Rain Networks agent

# Human handoff via email (the callback brief sent to the rep)
RESEND_API_KEY=re_...                # paste a ROTATED key — the old one was public
SALES_TEAM_EMAIL=stevewinfieldtx@gmail.com
SALES_REP_NAME=Steve
EMAIL_FROM=Rain Networks <onboarding@resend.dev>
HANDOFF_SEND_AVAILABILITY=true

# Optional legacy Slack ping — leave blank to use email only
SLACK_WEBHOOK_URL=


# ===== FRONTEND (VITE_ — shipped to the browser, PUBLIC, no secrets) =========
# Only needed if you deploy the separate Vite app in /frontend.
# The api.py demo page (/demo/live) does NOT use these — it uses ELEVENLABS_AGENT_ID above.

VITE_API_BASE=https://interactivechat.up.railway.app            # was localhost — point at prod
VITE_ELEVENLABS_AGENT_ID=agent_5101kty2ztmme25aspqycwp7mpsm     # MUST match the backend agent
VITE_PROJECT_NAME=Rain Networks Voice Agent
VITE_PROJECT_PAGE_CONTEXT=Browser-based Guardz advisor for IT partners — researches the partner's customers, maps pain points, and hands hot leads to a human via callback.


# ===== DELETE / DO NOT SET (these leaked secrets to the browser) =============
#   VITE_RESEND_API_KEY        -> removed; use RESEND_API_KEY above
#   VITE_ELEVENLABS_API_KEY    -> removed; use ELEVENLABS_API_KEY above
#
# Old Node-backend leftovers — unused by api.py, safe to drop:
#   DATABASE_PATH
#   OPENROUTER_MODEL_ANALYSIS
#   OPENROUTER_MODEL_RESEARCH
#   OPENROUTER_SITE_URL
#   OPENROUTER_SITE_NAME
#
# Heads-up: VITE_ELEVENLABS_AGENT_ID was "NDTYOmYEjbDIVCKB35i3" — a DIFFERENT agent
# than the one I configured. Use agent_5101kty2ztmme25aspqycwp7mpsm everywhere.
